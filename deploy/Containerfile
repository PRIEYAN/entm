# arm64 serving image for MarianMT en→hi (CTranslate2 int8).
#
# Build context is the PROJECT ROOT:
#   podman build -f deploy/Containerfile .
#
# Base is python:3.11-slim (glibc) — manylinux wheels need glibc, not musl.

FROM python:3.11-slim

ENV OMP_NUM_THREADS=2 \
    CT2_INTER_THREADS=1 \
    CT2_INTRA_THREADS=2 \
    CT2_MODEL_DIR=/app/model_cache_compact_ct2 \
    TOKENIZER_DIR=/app/model_cache_compact_ct2 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements/docker.txt ./requirements-docker.txt
RUN pip install --no-cache-dir -r requirements-docker.txt

COPY it2edge/ /app/it2edge/

# Marian CT2 package includes tokenizer files (copied by convert_ct2).
COPY model_cache_compact_ct2/ /app/model_cache_compact_ct2/

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')"

CMD ["uvicorn", "it2edge.serve.app:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "1"]
